generator client {
  provider               = "prisma-client"
  output                 = "../app/utils/prisma/client"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  email     String    @unique
  name      String?
  journeys  Journey[]
}

enum JourneyType {
  DEPARTURES
  PLANS
}

model Journey {
  id            Int         @id @default(autoincrement())
  createdAt     DateTime    @default(now())
  firstStation  String
  secondStation String
  name          String
  type          JourneyType @default(DEPARTURES)
  author        User        @relation(fields: [authorId], references: [id])
  authorId      Int
}
